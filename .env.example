# LM Studio (local, OpenAI-compatible). Leave as-is for default local install.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=mistral-7b-instruct-v0.3

# Langfuse (self-hosted). Leave blank to disable tracing entirely (no-op).
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
